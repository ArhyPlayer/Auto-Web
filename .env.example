# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=

# JWT для админ-панели (секретный ключ, минимум 32 символа)
JWT_SECRET=change-me-in-production-secret-key-32chars

# Swagger/OpenAPI: 1=true чтобы включить /api/docs (по умолчанию выключено)
# ENABLE_DOCS=1
