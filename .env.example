# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=

# pgAdmin  (доступ: http://<server-ip>:8080)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=

# Docker Registry  (доступ: docker login <server-ip>:5000)
REGISTRY_USER=registry_user
REGISTRY_PASSWORD=
REGISTRY_HOST=<server-ip>:5000
