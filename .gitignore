# ─── Секреты и окружение ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Registry ─────────────────────────────────────────────────────────────────
# htpasswd содержит хэши паролей — не коммитим
registry/auth/htpasswd

# ─── Nginx ────────────────────────────────────────────────────────────────────
# SSL-сертификаты (когда появятся)
nginx/ssl/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ─── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
